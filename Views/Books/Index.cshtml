@model IEnumerable<BookShop.Models.Book>
@{
    ViewData["Title"] = "Book Catalog";
}

<h2 class="mb-4">Book Catalog</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by title or author..." />
    </div>
    <div class="col-md-4">
        <select name="genre" class="form-select">
            <option value="">All genres</option>
            @foreach (var g in (ViewBag.Genres as List<string>) ?? new List<string>())
            {
                <option value="@g" selected="@(ViewBag.Genre == g)">@g</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Search</button>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="card h-100">
                <img src="@book.ImageUrl" class="card-img-top"
                     style="height: 220px; object-fit: cover;"
                     alt="@book.Title"
                     onerror="this.src='/images/no-cover.jpg'" />
                <div class="card-body">
                    <h5 class="card-title">@book.Title</h5>
                    <p class="text-muted mb-1">@book.Author</p>
                    <span class="badge bg-secondary mb-2">@book.Genre</span>
                    <p class="card-text small">@(book.Description.Length > 80 ? book.Description.Substring(0, 80) + "..." : book.Description)</p>
                    <p class="fw-bold text-primary fs-5 mb-1">@book.Price.ToString("F2") $</p>
                    @if (book.Stock > 0)
                    {
                        <small class="text-success">In stock: @book.Stock</small>
                    }
                    else
                    {
                        <small class="text-danger fw-bold">Out of stock</small>
                    }
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id"
                       class="btn btn-outline-primary flex-grow-1">Details</a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        if (book.Stock > 0)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <button type="submit" class="btn btn-success">Add to cart</button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary" disabled>Out of stock</button>
                        }
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="btn btn-outline-secondary">Login</a>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center mt-5">
        <h4>No books found</h4>
        <a asp-action="Index" class="btn btn-primary mt-2">Clear filter</a>
    </div>
}