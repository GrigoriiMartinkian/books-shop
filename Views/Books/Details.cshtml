@model BookShop.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="row mt-3">
    <div class="col-md-4">
        <img src="@Model.ImageUrl" class="img-fluid rounded shadow"
             alt="@Model.Title" style="max-height: 450px; width: 100%; object-fit: cover;">
    </div>
    <div class="col-md-8">
        <h1>@Model.Title</h1>
        <p class="text-muted fs-5">@Model.Author</p>
        <span class="badge bg-primary mb-3 fs-6">@Model.Genre</span>
        <p class="fs-5">@Model.Description</p>
        <h2 class="text-success">@Model.Price.ToString("F2") $</h2>

        <div class="mt-3">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Cart" asp-action="Add" method="post">
                    <input type="hidden" name="bookId" value="@Model.Id" />
                    <button type="submit" class="btn btn-success btn-lg">
                        🛒 Add to cart
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   class="btn btn-outline-primary btn-lg">
                    Login to purchase
                </a>
            }
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary mt-2">← Back to catalog</a>
    </div>
</div>

